# Banco de dados — troque user, password e cityrain pelos seus valores reais
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cityrain

# Banco usado nos testes (nunca use o banco de produção aqui)
TEST_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cityrain_test

# Chave de autenticação da Jetson (Bearer token)
API_KEY=troque_por_uma_chave_secreta_longa

# Diretório local onde as imagens da Jetson são salvas
UPLOAD_DIR=storage

# Origens permitidas no CORS (separadas por vírgula entre colchetes JSON)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# Tamanho máximo de upload em MB
MAX_UPLOAD_SIZE_MB=50
